{{! search results }}
<div class="container section">
    <h1>Search Results</h1>
    <p>Showing <strong>{{resultCount}}</strong> result(s) for "<strong>{{query}}</strong>"</p>
    <hr><br>

    {{#if establishments.length}}
        <div class="establishment-grid">
            {{#each establishments}}
                <div class="card">
                    <img src="{{imageUrl}}" alt="{{name}}" class="card-image">
                    <div class="card-content">
                        <h3>{{name}}</h3>
                        <p>{{cuisineType}} | {{priceRange}}</p>
                        <p>{{location}}</p>
                        <p>Rating: {{rating}} ⭐</p>
                        <div class="tag-container">
                            {{#each tags}}
                                <span class="tag">{{this}}</span>
                            {{/each}}
                        </div>
                        <a href="/establishments/{{_id}}" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="card" style="text-align:center; padding: 2rem;">
            <h3>No results found</h3>
            <p>Try searching with a different keyword.</p>
            <a href="/establishments" class="btn btn-outline">Browse All Establishments</a>
        </div>
    {{/if}}
</div>
